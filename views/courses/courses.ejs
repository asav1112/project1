<!-- custom js file link  -->
<script src="js/script.js"></script>
<script>
   document.getElementById('logout-btn')?.addEventListener('click', function(e) {
      e.preventDefault();
      fetch('/api/logout', {
         method: 'POST',
         headers: {
            'Content-Type': 'application/json'
         }
      })
      .then(response => response.json())
      .then(data => {
         if (data.success) {
            window.location.href = '/';
         }
      });
   });
</script>

   
