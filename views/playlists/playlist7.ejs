<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta http-equiv="X-UA-Compatible" content="IE=edge">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>DSA Playlist</title>

   <!-- font awesome cdn link  -->
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.2/css/all.min.css">

   <!-- custom css file link  -->
   <link rel="stylesheet" href="/CSS/style.css">

</head>
<body>

<header class="header">
   
   <section class="flex">

      <a href="/" class="logo"><img src="images/logo2.png" class="image" alt="StudyBridge"></a>

      <form action="/search" method="get" class="search-form">
         <input type="text" name="search" required placeholder="search courses..." maxlength="100">
         <button type="submit" class="fas fa-search"></button>
      </form>

      <div class="icons">
         <div id="menu-btn" class="fas fa-bars"></div>
         <div id="search-btn" class="fas fa-search"></div>
         <div id="user-btn" class="fas fa-user"></div>
         <div id="toggle-btn" class="fas fa-sun"></div>
      </div>

      <div class="profile">
         <img src="images/pic-1.jpg" class="image" alt="">
         <h3 class="name"><%= user ? user.name : 'Guest' %></h3>
         <p class="role"><%= user ? 'Student' : 'Guest' %></p>
         <a href="/profile" class="btn">view profile</a>
         <div class="flex-btn">
            <% if (user) { %>
               <a href="#" id="logout-btn" class="option-btn">logout</a>
            <% } else { %>
               <a href="/login" class="option-btn">login</a>
               <a href="/register" class="option-btn">register</a>
            <% } %>
         </div>
      </div>

   </section>

</header>   

<div class="side-bar">

   <div id="close-btn">
      <i class="fas fa-times"></i>
   </div>

   <div class="profile">
      <img src="images/pic-1.jpg" class="image" alt="">
      <h3 class="name"><%= user ? user.name : 'Guest' %></h3>
      <p class="role"><%= user ? 'Student' : 'Guest' %></p>
      <a href="/profile" class="btn">view profile</a>
   </div>

   <nav class="navbar">
      <a href="/"><i class="fas fa-home"></i><span>home</span></a>
      <a href="/about"><i class="fas fa-question"></i><span>about</span></a>
      <a href="/courses"><i class="fas fa-graduation-cap"></i><span>courses</span></a>
      <a href="/teachers"><i class="fas fa-chalkboard-user"></i><span>Admin</span></a>
      <a href="/contact"><i class="fas fa-headset"></i><span>contact us</span></a>
   </nav>

</div>

<section class="playlist-details">

   <h1 class="heading">playlist details</h1>

   <div class="row">

      <div class="column">
         <form action="" method="post" class="save-playlist">
            <button type="submit"><i class="far fa-bookmark"></i> <span>save playlist</span></button>
         </form>
   
         <div class="thumb">
            <img src="images/thumb-8.png" alt="">
            <span>6 videos</span>
         </div>
      </div>
      <div class="column">
         <div class="tutor">
            <img src="images/vishnu.jpg" alt="">
            <div>
               <h3>Vishnu Teli</h3>
               <span>5-1-2025</span>
            </div>
         </div>
   
         <div class="details">
            <h3>complete DSA tutorial</h3>
            <p>Master Data Structures and Algorithms with practical examples</p>
            <a href="/teacher-profile7" class="inline-btn">view profile</a>
         </div>
      </div>
   </div>

</section>

<section class="playlist-videos">

   <h1 class="heading">playlist videos</h1>

   <div class="box-container">

      <a class="box" href="/watch?playlist=7&video=1">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Introduction to DSA (part 01)</h3>
      </a>

      <a class="box" href="/watch?playlist=7&video=2">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Arrays and Strings (part 02)</h3>
      </a>

      <a class="box" href="/watch?playlist=7&video=3">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Linked Lists (part 03)</h3>
      </a>

      <a class="box" href="/watch?playlist=7&video=4">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Stacks and Queues (part 04)</h3>
      </a>

      <a class="box" href="/watch?playlist=7&video=5">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Trees and Graphs (part 05)</h3>
      </a>

      <a class="box" href="/watch?playlist=7&video=6">
         <i class="fas fa-play"></i>
         <img src="images/thumb-7.png" alt="">
         <h3>Sorting Algorithms (part 06)</h3>
      </a>

   </div>

</section>

<!-- Footer Section -->
<section class="footer">
   <div class="footer-content">
     <div class="footer-col">
       <h3>Quick Links</h3>
       <ul>
         <li><a href="/">Home</a></li>
         <li><a href="/about">About Us</a></li>
         <li><a href="/courses">Courses</a></li>
         <li><a href="/teachers">Admins(Teachers)</a></li>
         <li><a href="/contact">Contact Us</a></li>
       </ul>
     </div>
     
     <div class="footer-col">
       <h3>Connect With Us</h3>
       <div class="social-icons">
         <a href="#"><i class="fab fa-instagram"></i></a>
         <a href="#"><i class="fab fa-linkedin"></i></a>
         <a href="#"><i class="fab fa-twitter"></i></a>
         <a href="#"><i class="fab fa-youtube"></i></a>
       </div>
     </div>
     <div class="footer-col">
       <h3>Contact</h3>
       <p>Email: ui23cs38@iiitsurat.ac.in</p>
       <p>Phone: +91 9638674102</p>
     </div>
     
     <div class="footer-col">
        <h3>Courses Quick Links</h3>
        <ul>
           <li><a href="/courses?topic=html">HTML</a></li>
           <li><a href="/courses?topic=css">CSS</a></li>
           <li><a href="/courses?topic=javascript">JavaScript</a></li>
           <li><a href="/courses?topic=dsa">DSA</a></li>
           <li><a href="/courses?topic=software">Software Engineering</a></li>
         </ul>
      </div>
      
   </div>
   <div class="footer-bottom">
     <p>&copy; 2025 StudyPath. All rights reserved.</p>
   </div>
</section>

<!-- custom js file link  -->
<script src="js/script.js"></script>

</body>
</html> 