<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta http-equiv="X-UA-Compatible" content="IE=edge">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>home</title>
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.2/css/all.min.css">
   <link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="header">
   <section class="flex">
      <a href="/" class="logo"><img src="images/logo2.png" class="image" alt="StudyBridge"></a>
      <form action="/search" method="get" class="search-form">
         <input type="text" name="search" required placeholder="search courses..." maxlength="100">
         <button type="submit" class="fas fa-search"></button>
      </form>
      <div class="icons">
         <div id="menu-btn" class="fas fa-bars"></div>
         <div id="search-btn" class="fas fa-search"></div>
         <div id="user-btn" class="fas fa-user"></div>
         <div id="toggle-btn" class="fas fa-sun"></div>
      </div>
      <div class="profile">
         <img src="images/pic-1.jpg" class="image" alt="">
         <h3 class="name"><%= user ? user.name : 'student1' %></h3>
         <p class="role"><%= user ? user.role : 'Student' %></p>
         <% if (user) { %>
            <a href="/profile" class="btn">view profile</a>
            <a href="/api/logout" class="option-btn" id="logout-btn">logout</a>
         <% } else { %>
            <a href="/login" class="option-btn">login</a>
            <a href="/register" class="option-btn">register</a>
         <% } %>
      </div>
   </section>
</header>   

<div class="side-bar">
   <div id="close-btn">
      <i class="fas fa-times"></i>
   </div>
   <div class="profile">
      <img src="<%= user && user.name === 'Sakhee Mate' ? 'images/sakhee.jpg' : 
                  user && user.name === 'Asav Mahyavanshi' ? 'images/asav2.jpg' : 
                  user && user.name === 'Aman Dudi' ? 'images/dudi.jpg' : 
                  'images/pic-1.jpg' %>" class="image" alt="">
      <h3 class="name"><%= user ? user.name : 'Guest' %></h3>
      <p class="role"><%= user ? user.role : 'Guest' %></p>
      <a href="/profile" class="btn">view profile</a>
   </div>
   <nav class="navbar">
      <a href="/"><i class="fas fa-home"></i><span>home</span></a>
      <a href="/about"><i class="fas fa-question"></i><span>about</span></a>
      <a href="/courses"><i class="fas fa-graduation-cap"></i><span>courses</span></a>
      <a href="/teachers"><i class="fas fa-chalkboard-user"></i><span>Admin</span></a>
      <a href="/contact"><i class="fas fa-headset"></i><span>contact us</span></a>
   </nav>
</div>

<section class="home-grid">
   <h1 class="heading">quick options</h1>
   <div class="box-container">
      <div class="box">
         <h3 class="title">likes and comments</h3>
         <p class="likes">total likes : <span><%= likes || 25 %></span></p>
         <a href="/likes" class="inline-btn">view likes</a>
         <p class="likes">total comments : <span><%= comments || 12 %></span></p>
         <a href="/comments" class="inline-btn">view comments</a>
         <p class="likes">saved playlists : <span><%= playlists || 4 %></span></p>
         <a href="/courses" class="inline-btn">view playlists</a>
      </div>

      <div class="box">
         <h3 class="title">top categories</h3>
         <div class="flex">
            <a href="/courses?category=development"><i class="fas fa-code"></i><span>development</span></a>
            <a href="/courses?category=business"><i class="fas fa-chart-simple"></i><span>business</span></a>
            <a href="/courses?category=design"><i class="fas fa-pen"></i><span>design</span></a>
            <a href="/courses?category=marketing"><i class="fas fa-chart-line"></i><span>marketing</span></a>
            <a href="/courses?category=music"><i class="fas fa-music"></i><span>music</span></a>
            <a href="/courses?category=photography"><i class="fas fa-camera"></i><span>photography</span></a>
            <a href="/courses?category=software"><i class="fas fa-cog"></i><span>software</span></a>
            <a href="/courses?category=science"><i class="fas fa-vial"></i><span>science</span></a>
         </div>
      </div>

      <div class="box">
         <h3 class="title">popular topics</h3>
         <div class="flex">
            <a href="/courses?topic=html"><i class="fab fa-html5"></i><span>HTML</span></a>
            <a href="/courses?topic=css"><i class="fab fa-css3"></i><span>CSS</span></a>
            <a href="/courses?topic=javascript"><i class="fab fa-js"></i><span>javascript</span></a>
            <a href="/courses?topic=react"><i class="fab fa-react"></i><span>react</span></a>
            <a href="/courses?topic=php"><i class="fab fa-php"></i><span>PHP</span></a>
            <a href="/courses?topic=bootstrap"><i class="fab fa-bootstrap"></i><span>bootstrap</span></a>
         </div>
      </div>

      <div class="box">
         <h3 class="title">become a tutor</h3>
         <p class="tutor">Share your knowledge, inspire learners, and grow your teaching career online. Join our platform and start making a difference today!</p>
         <a href="/teachers" class="inline-btn">get started</a>
      </div>
   </div>
</section>

<section class="courses">
   <h1 class="heading">our courses</h1>
   <div class="box-container">
      <div class="box">
         <div class="tutor">
            <img src="images/asav2.jpg" alt="">
            <div class="info">
               <h3>Asav Mahyavanshi</h3>
               <span>10-4-2025</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/dsa.png" alt="">
            <span>6+ videos</span>
         </div>
         <h3 class="title">complete DSA tutorial</h3>
         <a href="/playlist1" class="inline-btn">view playlist</a>
      </div>

      <div class="box">
         <div class="tutor">
            <img src="images/sakhee.jpg" alt="">
            <div class="info">
               <h3>Sakhee Mate</h3>
               <span>11-3-20225</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/thumb-2.png" alt="">
            <span>9+ videos</span>
         </div>
         <h3 class="title">complete CSS tutorial</h3>
         <a href="/playlist2" class="inline-btn">view playlist</a>
      </div>

      <div class="box">
         <div class="tutor">
            <img src="images/aman.jpg" alt="">
            <div class="info">
               <h3>Aman Dudi</h3>
               <span>21-10-2022</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/thumb-3.png" alt="">
            <span>10 videos</span>
         </div>
         <h3 class="title">complete JS tutorial</h3>
         <a href="/playlist3" class="inline-btn">view playlist</a>
      </div>

      <div class="box">
         <div class="tutor">
            <img src="images/pic-5.jpg" alt="">
            <div class="info">
               <h3>Jibby mam</h3>
               <span>21-10-2022</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/thumb-4.png" alt="">
            <span>10 videos</span>
         </div>
         <h3 class="title">complete Boostrap tutorial</h3>
         <a href="/playlist4" class="inline-btn">view playlist</a>
      </div>

      <div class="box">
         <div class="tutor">
            <img src="images/pic-6.jpg" alt="">
            <div class="info">
               <h3>Rishi sir</h3>
               <span>21-10-2022</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/thumb-5.png" alt="">
            <span>10 videos</span>
         </div>
         <h3 class="title">complete JQuery tutorial</h3>
         <a href="/playlist5" class="inline-btn">view playlist</a>
      </div>

      <div class="box">
         <div class="tutor">
            <img src="images/pic-7.jpg" alt="">
            <div class="info">
               <h3>Jahnavi Mahyavanshi</h3>
               <span>21-10-2022</span>
            </div>
         </div>
         <div class="thumb">
            <img src="images/thumb-6.png" alt="">
            <span>10 videos</span>
         </div>
         <h3 class="title">complete SASS tutorial</h3>
         <a href="/playlist6" class="inline-btn">view playlist</a>
      </div>
   </div>
   <div class="more-btn">
      <a href="/courses" class="inline-option-btn">view all courses</a>
   </div>
</section>

<script src="js/script.js"></script>
<script>
   document.getElementById('logout-btn')?.addEventListener('click', function(e) {
      e.preventDefault();
      fetch('/api/logout', {
         method: 'POST',
         headers: {
            'Content-Type': 'application/json'
         }
      })
      .then(response => response.json())
      .then(data => {
         if (data.success) {
            window.location.href = '/';
         }
      });
   });
</script>
</body>
</html>